  "authors": ["Cukkoo"],
  "contact": { "sources": "https://github.com/Cukkoo12/SoundCulling" },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.cukkoo.soundculling.SoundCulling"],
    "modmenu": ["com.cukkoo.soundculling.integration.ModMenuIntegration"]
  },
  "mixins": ["soundculling.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16.9",
    "fabric-api": ">=0.92.2",
    "minecraft": ">=1.20.1"
  },
  "suggests": {
    "modmenu": "*"
  }
}
